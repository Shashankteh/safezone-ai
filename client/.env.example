# ── API ──────────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# ── Mapbox ───────────────────────────────────────────────────────────────────
# Get free key at mapbox.com → Account → Access Tokens
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_public_token

# ── Encryption ───────────────────────────────────────────────────────────────
REACT_APP_ENCRYPTION_KEY=your-32-char-aes-encryption-key!!

# ── Firebase (Web Push) ──────────────────────────────────────────────────────
REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key
REACT_APP_FIREBASE_API_KEY=your_firebase_web_api_key
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id
